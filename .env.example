# 複製為 .env 後填入真實值（勿提交 .env）
# 完整變數說明與執行範例：Docs/env_and_run.md

# Google Gemini（練習用）
GOOGLE_API_KEY=

# 選用：FastAPI checkpoint 檔路徑（相對專案根；預設 data/langgraph_checkpoints.sqlite）
# LANGGRAPH_CHECKPOINT_DB=data/langgraph_checkpoints.sqlite

# 選用：LangSmith 雲端 tracing
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=LangGraph_Learning
# M2 選用：LLM-as-judge 模型（practice_15_eval_smoke.py --enable-llm-judge）
# M2_JUDGE_MODEL=gemini-3-flash-preview
# M2 選用：LLM-as-judge 模板（strict 或 lenient）
# M2_JUDGE_TEMPLATE=lenient
# M2 選用：LLM-as-judge 維度（逗號分隔）
# M2_JUDGE_DIMENSIONS=relevance,helpfulness,groundedness
# M2 選用：429/暫時性錯誤重試設定（target 與 judge 共用）
# M2_RETRY_ATTEMPTS=3
# M2_RETRY_MAX_WAIT_SECONDS=8
# M2 選用：保底模式（judge 失敗時自動降級為 keyword-only）
# M2_FALLBACK_TO_KEYWORD_ON_JUDGE_ERROR=true

# 選用：本機終端機 logging（見 Docs/logging_setup.md）
# AGENT_LOGGING=true
# AGENT_LOGGING_LEVEL=INFO

# H4：模型訊息前處理（filter -> trim）
# 最多保留 token 單位（目前 agent_graph 以「每則訊息=1」教學計數）
# MODEL_MAX_TOKENS=20
# trim 策略：last 或 first
# MODEL_TRIM_STRATEGY=last
# 是否保留最前面的 system 訊息
# MODEL_TRIM_INCLUDE_SYSTEM=true
# 裁剪後的起點型別（常用 human；留空代表不限制）
# MODEL_TRIM_START_ON=human
# 先過濾要排除的訊息型別（逗號分隔）
# 可用：human, ai, system, tool（或 HumanMessage, AIMessage...）
# MODEL_EXCLUDE_TYPES=

# J1/J2：Lilian Weng Chroma（預設路徑為專案根目錄下 data/chroma/lilianweng）
# LILIAN_CHROMA_DIR=
# LILIAN_CHROMA_COLLECTION=lilian_weng_posts
# J1/J2：Gemini embedding 模型（留空則自動 fallback）
# J1_EMBED_MODEL=

# N1-P4（選用）：Rerank（Gemini pointwise scoring；會額外呼叫模型）
# 預設關閉；也可在工具參數 `rerank=true` 明確啟用（優先於環境變數）
# LILIAN_RERANK_ENABLED=false
# LILIAN_RERANK_MODEL=gemini-3-flash-preview

# N1-P5（選用）：Finalize（用 final_top_k 片段生成答案 + citations；會額外呼叫模型）
# LILIAN_ANSWER_MODEL=gemini-3-flash-preview

# practice_16_rag_advanced_smoke.py（N1-P7）建議執行參數
# 目前以 CLI 參數控制（不是用 .env）
# 1) 省 token 建議（預設）：隨機 3 題、每模式只 finalize 1 題、總 finalize 上限 3
#    py -3.11 practice_16_rag_advanced_smoke.py --sample-size 3 --random-seed 42 --answer-per-mode 1 --max-finalize-calls 3
# 2) 更保守（避免 429）：總 finalize 上限 2
#    py -3.11 practice_16_rag_advanced_smoke.py --sample-size 3 --random-seed 42 --answer-per-mode 1 --max-finalize-calls 2
# 3) 純檢索比較（不生成答案，0 次 finalize）
#    py -3.11 practice_16_rag_advanced_smoke.py --sample-size 3 --random-seed 42 --max-finalize-calls 0
